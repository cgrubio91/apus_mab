# ============================================
# 🔑 AI CONFIGURATION (Gemini or Ollama)
# ============================================
# Options: gemini, ollama
AI_PROVIDER=gemini

# Gemini settings (default)
# Get your API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Ollama settings (when AI_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# ============================================
# 🗄️ DATABASE CONFIGURATION (PostgreSQL - Google Cloud SQL)
# ============================================
DB_HOST=your-db-host
# Usa 5433 si usas docker-compose (mapea 5433→5432), 5432 para conexión directa
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSLMODE=require
# Pool de conexiones (opcional, default min=1 max=10)
# DB_POOL_MIN=1
# DB_POOL_MAX=10

# Optional: Cloud SQL connection name for Unix socket (when using Cloud SQL Auth Proxy)
# Format: project:region:instance
# CLOUD_SQL_CONNECTION_NAME=your-project:your-region:your-instance

# ============================================
# 📱 TWILIO CONFIGURATION (Optional - for WhatsApp)
# ============================================
# Get your credentials at https://console.twilio.com
ACCOUNT_SID=your-twilio-account-sid
AUTH_TOKEN=your-twilio-auth-token
FROM_WHATSAPP=whatsapp:+14155238886

# ============================================
# 🚀 SERVER CONFIGURATION
# ============================================
PORT=10000

# Environment: development, production
# ENV=development

# CORS allowed origins (comma-separated, no spaces)
# En producción, NUNCA uses "*". Especifica orígenes exactos.
# CORS_ORIGINS=http://localhost:4200,https://your-frontend.com
